# Ignore bulky training data we don't need at runtime, but KEEP the
# files that gemini_client._load_few_shot_block reads at startup to inject
# reference examples into SYSTEM_PROMPT. The loader prefers
# training_examples.json (full 600 entries) and falls back to the smaller
# fewshot file if the full one is missing.
training_data_raw.json
analyze_bugs.py
extract_training.py
bug_analysis_output.txt
bug_analysis_full.txt

# Ignore dev/docs files
README.md
USER_GUIDE.md
DEPLOYMENT.md
.env.example
.gitignore
.git/
__pycache__/
*.pyc
*.pyo
*.md
.env
venv/
.venv/
# NOTE: service-account.json MUST NOT be in this file.
# Same reason as .gcloudignore — Phase 2 needs it to download attachments
# and send Chat replies.
