# reads it at startup to inject 5 reference examples into SYSTEM_PROMPT.
training_data_raw.json
training_examples.json
analyze_bugs.py
extract_training.py
bug_analysis_output.txt
bug_analysis_full.txt

# Ignore dev/docs files
README.md
USER_GUIDE.md
DEPLOYMENT.md
.env.example
.gitignore
.git/
__pycache__/
*.pyc
*.pyo
*.md
.env
venv/
